# Development environment — cp .env.example .env and fill in values.
# Secrets belong in .env only (.env is gitignored).

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=maildev
POSTGRES_DB=mail
POSTGRES_PORT=55432

# DSN the app connects with (when running maild on the host)
MAIL_DSN=postgres://mail:maildev@localhost:55432/mail

# IMAP listen address (default :1143)
MAIL_IMAP_ADDR=:1143

# SMTP receive (MX) address (default :2525)
MAIL_SMTP_ADDR=:2525

# SMTP submission (AUTH required) address (default :2587)
MAIL_SUBMISSION_ADDR=:2587

# SMTPS submission (implicit TLS, RFC 8314) address (default :2465).
# Only starts when MAIL_TLS_CERT/KEY are set. Exposed as port 465.
#MAIL_SMTPS_ADDR=:2465

# Server name used in Received headers / EHLO
MAIL_HOSTNAME=mail.example.com

# TLS for the protocol ports (IMAP implicit TLS + SMTP STARTTLS).
# Empty = plaintext (behind a TLS-terminating proxy/tunnel, or dev).
#MAIL_TLS_CERT=/etc/mail/tls/tls.crt
#MAIL_TLS_KEY=/etc/mail/tls/tls.key

# DMARC policy enforcement on inbound mail (default: record only).
# true = honor the sender domain's published policy:
#   fail + p=reject     → 550 reject at DATA
#   fail + p=quarantine → deliver to Junk folder
#MAIL_DMARC_ENFORCE=true

# Inbound connection screening (default: enabled with zen.spamhaus.org).
# DNSBL-listed IPs are rejected at MAIL FROM (554); connections with neither
# forward-confirmed rDNS nor a plausible HELO are quarantined to Junk.
# Comma-separated DNSBL zones, or "off" to disable screening entirely.
# NOTE: DNSBL lookups use the system resolver — Spamhaus does not answer
# queries via large public resolvers (1.1.1.1/8.8.8.8).
#MAIL_DNSBL_ZONE=zen.spamhaus.org

# Greylisting (default: off). First contact from an unverified source gets
# 451; a retry after MAIL_GREYLIST_DELAY passes and the (source /24|/64,
# from, rcpt) triplet stays trusted. FCrDNS-verified senders are exempt.
#MAIL_GREYLIST=true
#MAIL_GREYLIST_DELAY=1m

# rspamd scanning (default: off). When set, inbound mail is scanned via the
# rspamd HTTP API (checkv2): reject-action mail is refused at DATA (554),
# add-header/greylist actions quarantine to Junk. Fail-open on scan errors.
#MAIL_RSPAMD_URL=http://rspamd:11333
# Optional shared password for the rspamd controller/scan endpoint.
#MAIL_RSPAMD_PASSWORD=

# NOTE: domains and outbound relays are managed entirely in the DB via the
# admin UI (/admin/domain, /admin/relay) — no env bootstrapping needed.
# Anyone can log in via OIDC; accounts get a mailbox only when their email
# domain is registered (retroactively backfilled when the domain is added).

# Integration tests (make db-test)
MAIL_TEST_DSN=postgres://mail:maildev@localhost:55432/mail

# ── Admin API + OIDC ────────────────────────────────────────
# Admin API listen address (default :8080)
MAIL_API_ADDR=:8080

# OIDC issuer — required. The server refuses to start without it unless
# MAIL_DEV_INSECURE=true is set explicitly (dev only: token verification
# skipped, every request is treated as admin — NEVER in production).
MAIL_OIDC_ISSUER=http://localhost:8480/realms/mail
# MAIL_DEV_INSECURE=true
MAIL_OIDC_CLIENT_ID=mail-web
# Admin group name (default mail-admin)
MAIL_ADMIN_GROUP=mail-admin

# web (RR7) side — passed as process env when running `bun run dev` in web/
#MAIL_OIDC_CLIENT_SECRET=mail-web-dev-secret
#MAIL_API_URL=http://localhost:8080
#SESSION_SECRET=change-me-in-production

# Prometheus metrics listener (cluster-internal — never expose via gateway).
# GET /metrics. Set empty to keep the default.
MAIL_METRIC_ADDR=:2112
