# mail 개발 환경 설정 — cp .env.example .env 후 값 채우기
# 비밀값은 .env에만. .env는 git에 안 올라감(.gitignore).

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=maildev
POSTGRES_DB=mail
POSTGRES_PORT=55432

# 앱이 붙을 DSN (호스트에서 go run 시 사용)
MAIL_DSN=postgres://mail:maildev@localhost:55432/mail

# IMAP 리슨 주소 (미설정 시 :1143)
MAIL_IMAP_ADDR=:1143

# SMTP 수신(MX) 주소 (미설정 시 :2525)
MAIL_SMTP_ADDR=:2525

# SMTP submission(제출, AUTH 필수) 주소 (미설정 시 :2587)
MAIL_SUBMISSION_ADDR=:2587

# Received 헤더/EHLO에 쓸 서버 이름
MAIL_HOSTNAME=mail.krisam.in

# ── 발송 relay (Phase 2-3, DD-04) ──────────────────────────
# 설정하면: 외부 도메인 제출 허용 + 발송 큐 워커 기동.
# 미설정이면: 외부 도메인 제출 550 거절 (로컬 배달만).
# 예: SES → email-smtp.ap-northeast-2.amazonaws.com:587
#MAIL_RELAY_ADDR=
#MAIL_RELAY_USERNAME=
#MAIL_RELAY_PASSWORD=
#MAIL_RELAY_STARTTLS=true

# 통합 테스트용 (make db-test)
MAIL_TEST_DSN=postgres://mail:maildev@localhost:55432/mail
