# Development environment — cp .env.example .env and fill in values.
# Secrets belong in .env only (.env is gitignored).

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=maildev
POSTGRES_DB=mail
POSTGRES_PORT=55432

# DSN the app connects with (when running maild on the host)
MAIL_DSN=postgres://mail:maildev@localhost:55432/mail

# IMAP listen address (default :1143)
MAIL_IMAP_ADDR=:1143

# SMTP receive (MX) address (default :2525)
MAIL_SMTP_ADDR=:2525

# SMTP submission (AUTH required) address (default :2587)
MAIL_SUBMISSION_ADDR=:2587

# Server name used in Received headers / EHLO
MAIL_HOSTNAME=mail.example.com

# TLS for the protocol ports (IMAP implicit TLS + SMTP STARTTLS).
# Empty = plaintext (behind a TLS-terminating proxy/tunnel, or dev).
#MAIL_TLS_CERT=/etc/mail/tls/tls.crt
#MAIL_TLS_KEY=/etc/mail/tls/tls.key

# DMARC policy enforcement on inbound mail (default: record only).
# true = honor the sender domain's published policy:
#   fail + p=reject     → 550 reject at DATA
#   fail + p=quarantine → deliver to Junk folder
#MAIL_DMARC_ENFORCE=true

# Comma-separated domains ensured on boot (idempotent).
# Solves the empty-DB chicken-and-egg: the login gate rejects unregistered
# domains, but a fresh install has no domains yet. Accounts are created by
# JIT provisioning on first login — only domains need bootstrapping.
#MAIL_BOOTSTRAP_DOMAIN=example.com,other.example

# ── Outbound relay fallback ─────────────────────────────────
# Relays are managed in the DB (admin UI /admin/relay) — these env vars are
# only a fallback when no DB relay exists. Prefer the admin UI: changes
# apply without a restart.
#
# Example with Resend:
#   1) Sign up at https://resend.com and add your domain
#   2) Register the DNS records Resend gives you (SPF/DKIM), verify
#   3) Create an API key (Sending access is enough)
#   4) In /admin/relay: host=smtp.resend.com port=587
#      username=resend password=<API key>
#MAIL_RELAY_ADDR=smtp.resend.com:587
#MAIL_RELAY_USERNAME=resend
#MAIL_RELAY_PASSWORD=re_xxxxxxxxxxxx
#MAIL_RELAY_STARTTLS=true

# Integration tests (make db-test)
MAIL_TEST_DSN=postgres://mail:maildev@localhost:55432/mail

# ── Admin API + OIDC ────────────────────────────────────────
# Admin API listen address (default :8080)
MAIL_API_ADDR=:8080

# OIDC issuer (empty = dev mode: token verification skipped, everyone is admin)
MAIL_OIDC_ISSUER=http://localhost:8480/realms/mail
MAIL_OIDC_CLIENT_ID=mail-web
# Admin group name (default mail-admin)
MAIL_ADMIN_GROUP=mail-admin

# web (RR7) side — passed as process env when running `bun run dev` in web/
#MAIL_OIDC_CLIENT_SECRET=mail-web-dev-secret
#MAIL_API_URL=http://localhost:8080
#SESSION_SECRET=change-me-in-production
