# mail 개발 환경 설정 — cp .env.example .env 후 값 채우기
# 비밀값은 .env에만. .env는 git에 안 올라감(.gitignore).

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=maildev
POSTGRES_DB=mail
POSTGRES_PORT=55432

# 앱이 붙을 DSN (호스트에서 go run 시 사용)
MAIL_DSN=postgres://mail:maildev@localhost:55432/mail

# IMAP 리슨 주소 (미설정 시 :1143)
MAIL_IMAP_ADDR=:1143

# SMTP 수신(MX) 주소 (미설정 시 :2525)
MAIL_SMTP_ADDR=:2525

# SMTP submission(제출, AUTH 필수) 주소 (미설정 시 :2587)
MAIL_SUBMISSION_ADDR=:2587

# Received 헤더/EHLO에 쓸 서버 이름
MAIL_HOSTNAME=mail.krisam.in

# ── 발송 relay (Phase 2-3, DD-04) ──────────────────────────
# 설정하면: 외부 도메인 제출 허용 + 발송 큐 워커 기동.
# 미설정이면: 외부 도메인 제출 550 거절 (로컬 배달만).
# ★우리 서버에 있는 도메인끼리는 relay를 안 거치고 내부 배달됨.
#
# Resend (선택된 relay — 2026-07):
#   1) https://resend.com 가입 → 대시보드에서 krisam.in 도메인 추가
#   2) Resend가 주는 DNS 레코드(SPF/DKIM)를 Cloudflare에 등록 → 검증
#   3) API Key 발급 (Sending access면 충분)
#   4) 아래 채우기 — username은 문자열 'resend' 고정, password에 API 키
#MAIL_RELAY_ADDR=smtp.resend.com:587
#MAIL_RELAY_USERNAME=resend
#MAIL_RELAY_PASSWORD=re_xxxxxxxxxxxx
#MAIL_RELAY_STARTTLS=true

# 통합 테스트용 (make db-test)
MAIL_TEST_DSN=postgres://mail:maildev@localhost:55432/mail

# ── Admin API + OIDC (Phase 3) ──────────────────────────────
# Admin API 리슨 주소 (미설정 시 :8080)
MAIL_API_ADDR=:8080

# OIDC issuer (미설정 시 dev 모드 — 토큰 검증 skip, 전부 admin 취급)
MAIL_OIDC_ISSUER=http://localhost:8480/realms/mail
MAIL_OIDC_CLIENT_ID=mail-web
# 관리자 그룹 (기본 mail-admin)
MAIL_ADMIN_GROUP=mail-admin

# web (RR7) 쪽 — web/에서 bun run dev 시 프로세스 env로 전달
#MAIL_OIDC_CLIENT_SECRET=mail-web-dev-secret
#MAIL_API_URL=http://localhost:8080
#SESSION_SECRET=change-me-in-production
