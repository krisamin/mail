# mail 개발 환경 설정 — cp .env.example .env 후 값 채우기
# 비밀값은 .env에만. .env는 git에 안 올라감(.gitignore).

# ── Postgres (dev) ──────────────────────────────────────────
POSTGRES_USER=mail
POSTGRES_PASSWORD=maildev
POSTGRES_DB=mail
POSTGRES_PORT=55432

# 앱이 붙을 DSN (호스트에서 go run 시 사용)
MAIL_DSN=postgres://mail:maildev@localhost:55432/mail

# IMAP 리슨 주소 (미설정 시 :1143)
MAIL_IMAP_ADDR=:1143

# 통합 테스트용 (make db-test)
MAIL_TEST_DSN=postgres://mail:maildev@localhost:55432/mail
